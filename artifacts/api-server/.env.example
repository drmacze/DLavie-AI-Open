# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Models (optional — local model works without these)
XAI_API_KEY=           # Get from console.x.ai (for Grok 3 Mini / Grok 3)
GEMINI_API_KEY=        # Get from aistudio.google.com (for Gemini 2.0/2.5)

# Payment — Midtrans
MIDTRANS_SERVER_KEY=   # From dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_CLIENT_KEY=   # From dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_IS_PRODUCTION=false   # Set to true for production

# GitHub (optional)
GITHUB_PERSONAL_ACCESS_TOKEN=
